APP_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=10.20.50.21
DB_PORT=3306
DB_DATABASE=secondbyte_portal
DB_USERNAME=portal_app
DB_PASSWORD=PortalApp!2026

CACHE_DRIVER=file
